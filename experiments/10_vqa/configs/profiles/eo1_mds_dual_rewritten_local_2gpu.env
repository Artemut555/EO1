# Local 2-GPU smoke test for MDS dual filtered rewritten dataset.
# Run: PROFILE=eo1_mds_dual_rewritten_local_2gpu bash experiments/10_vqa/train.sh
# Source secrets.env first for S3 access: source ../../../../secrets.env
# Use eo_mds_dual_rewritten_local.yaml for local test (prepare_mds --local-test)
# Use eo_mds_dual_rewritten_s3.yaml when S3 MDS is ready (default)
DATASET=experiments/10_vqa/configs/data/eo_mds_dual_rewritten_s3.yaml
GPUS=2
MAX_STEPS=20
PER_DEVICE_BATCH_SIZE=2
GRADIENT_ACCUMULATION_STEPS=2
PACK_DATASET=False
SAVE_STEPS=9999
SAVE_TOTAL_LIMIT=1
LOGGING_STEPS=2
ATTN_IMPL=sdpa
S3_SSL_VERIFY=false
