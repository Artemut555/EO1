# Local 2-GPU smoke test with packing (EO-1-like). Use before launching full run on cloud.
# Small sample so packing runs quickly; full dataset + 5 epochs for cloud profile.
# Run: PROFILE=local_2gpu_pack DATASET=experiments/10_vqa/configs/data/eo_chatml_cleaned_s3_smoke.yaml bash experiments/10_vqa/train.sh
# (from EO1 repo root; conda env eo for S3; or use eo_chatml_cleaned_s3.yaml with first:300)
GPUS=2
MAX_STEPS=8
PER_DEVICE_BATCH_SIZE=1
GRADIENT_ACCUMULATION_STEPS=1
PACK_DATASET=True
MAX_PACKED_LENGTH=16384
CHUNK_SIZE=16
LR=5e-5
MERGER_LR=5e-5
VISION_LR=1e-5
WARMUP_RATIO=0.03
SAVE_STEPS=5
SAVE_TOTAL_LIMIT=1
LOGGING_STEPS=1
ATTN_IMPL=sdpa
