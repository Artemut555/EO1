# Micro packing test: ~10s total. 10 samples, 2 steps. From EO1 root: PROFILE=local_2gpu_pack_micro DATASET=experiments/10_vqa/configs/data/eo_chatml_cleaned_s3_micro.yaml bash experiments/10_vqa/train.sh
GPUS=2
MAX_STEPS=2
PER_DEVICE_BATCH_SIZE=1
GRADIENT_ACCUMULATION_STEPS=1
PACK_DATASET=True
MAX_PACKED_LENGTH=16384
CHUNK_SIZE=16
LR=5e-5
MERGER_LR=5e-5
VISION_LR=1e-5
WARMUP_RATIO=0.03
SAVE_STEPS=9999
SAVE_TOTAL_LIMIT=1
LOGGING_STEPS=1
ATTN_IMPL=sdpa
